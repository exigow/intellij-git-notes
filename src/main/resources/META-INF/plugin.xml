<idea-plugin>
    <id>intellij-git-notes</id>
    <name>Git Notes</name>
    <vendor>Jakub Błach</vendor>
    <description><![CDATA[
        This minimal plugin adds support for <a href="https://git-scm.com/docs/git-notes">git-notes</a> in IntelliJ IDEA.
    ]]></description>
    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>
    <resource-bundle>messageBundle</resource-bundle>
    <extensions defaultExtensionNs="com.intellij">
        <vcsLogCommitStatusProvider implementation="notes.status.NotesStatusProvider"/>
        <vcsLogCustomColumn implementation="notes.email.AuthorEmailColumn"/>
        <vcsLogCustomColumn implementation="notes.email.CommitterEmailColumn"/>
    </extensions>
    <actions>
        <action id="GitNotes.AddNote" class="notes.action.AddNoteAction">
            <add-to-group group-id="Git.Log.ContextMenu" anchor="after" relative-to-action="Git.CreateNewTag"/>
        </action>
        <group id="GitNotes.EditNote" class="notes.action.EditNoteGroup" popup="true">
            <add-to-group group-id="Git.Log.ContextMenu" anchor="after" relative-to-action="Git.Reword.Commit"/>
        </group>
    </actions>
</idea-plugin>
